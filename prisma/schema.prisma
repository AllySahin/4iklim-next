generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Slide {
  id          String   @id @default(cuid())
  image       String
  title       String
  subtitle    String
  description String
  ctaText     String
  ctaLink     String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  image         String
  category      String
  categoryColor String
  title         String
  status        String
  location      String
  target        String
  reached       String
  percent       Int      @default(0)
  description   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  src       String
  category  String
  title     String
  location  String
  span      String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Volunteer {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  email        String
  ageGroup     String   @default("")
  area         String
  availability String   @default("")
  travel       String   @default("")
  note         String   @default("")
  kvkkConsent  Boolean  @default(false)
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}
